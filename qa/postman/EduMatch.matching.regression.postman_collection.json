  },
  "item": [
    {
      "name": "01 Register Applicant",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = (Date.now() % 1000).toString().padStart(3, '0');",
              "const username6 = `u${suffix}x${Math.floor(Math.random() * 10)}`;",
              "pm.environment.set('signupUsername', username6);",
              "pm.environment.set('signupEmail', `${username6}@example.com`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is valid', function () {",
              "  pm.expect(pm.response.code).to.be.oneOf([200, 201, 400]);",
              "});",
              "pm.test('Response is JSON', function () {",
              "  pm.response.to.be.json;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{signupUsername}}\",\n  \"email\": \"{{signupEmail}}\",\n  \"password\": \"123456\",\n  \"firstName\": \"Matching\",\n  \"lastName\": \"Applicant\",\n  \"sex\": \"MALE\"\n}"
        },
        "url": {
          "raw": "{{auth_base_url}}/api/auth/signup",
          "host": [
            "{{auth_base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "signup"
          ]
        }
      },
      "response": []
    },
    {
      "name": "02 Applicant Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.environment.set('accessToken', json.accessToken);",
              "pm.environment.set('refreshToken', json.refreshToken);",
              "pm.test('Applicant tokens exist', function () {",
              "  pm.expect(json.accessToken).to.be.a('string').and.not.empty;",
              "  pm.expect(json.refreshToken).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{signupUsername}}\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{auth_base_url}}/api/auth/signin",
          "host": [
            "{{auth_base_url}}"
          ],
          "path": [
            "api",
            "auth",
            "signin"
          ]
        }
      },
      "response": []
    },
    {
      "name": "03 Get User Me",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.environment.set('userId', String(json.id));",
              "pm.environment.set('applicantId', String(json.id));",
              "pm.test('Applicant id exists', function () {",
              "  pm.expect(json.id).to.exist;",
              "  pm.expect(json.username).to.be.a('string').and.not.empty;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{auth_base_url}}/api/user/me",
          "host": [
            "{{auth_base_url}}"
          ],
          "path": [
            "api",
            "user",
            "me"
          ]
        }
      },
      "response": []
    },
