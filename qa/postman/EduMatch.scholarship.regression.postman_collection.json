    {
      "name": "10 Create Opportunity",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const now = new Date();",
              "const suffix = `${Date.now()}${Math.floor(Math.random() * 1000)}`;",
              "const deadline = new Date(now.getTime() + 45 * 24 * 60 * 60 * 1000);",
              "const start = new Date(now.getTime() + 60 * 24 * 60 * 60 * 1000);",
              "const end = new Date(now.getTime() + 240 * 24 * 60 * 60 * 1000);",
              "const toDate = (value) => value.toISOString().slice(0, 10);",
              "pm.environment.set('opportunityTitle', `QA Scholarship ${suffix}`);",
              "pm.environment.set('updatedOpportunityTitle', `QA Scholarship Updated ${suffix}`);",
              "pm.environment.set('applicationDeadline', toDate(deadline));",
              "pm.environment.set('startDate', toDate(start));",
              "pm.environment.set('endDate', toDate(end));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.environment.set('opportunityId', json.id);",
              "pm.test('Opportunity id exists', function () {",
              "  pm.expect(json.id).to.exist;",
              "  pm.expect(json.title).to.eql(pm.environment.get('opportunityTitle'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{employerAccessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{opportunityTitle}}\",\n  \"fullDescription\": \"Regression scholarship created by Newman.\",\n  \"applicationDeadline\": \"{{applicationDeadline}}\",\n  \"startDate\": \"{{startDate}}\",\n  \"endDate\": \"{{endDate}}\",\n  \"scholarshipAmount\": 5000000,\n  \"minGpa\": 3.0,\n  \"studyMode\": \"FULL_TIME\",\n  \"level\": \"UNDERGRADUATE\",\n  \"isPublic\": true,\n  \"contactEmail\": \"contact@test.com\",\n  \"website\": \"https://example.com\",\n  \"tags\": [\"Tech\", \"Scholarship\"],\n  \"requiredSkills\": [\"Java\", \"English\"]\n}"
        },
