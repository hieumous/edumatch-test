              "const suffix = `${Date.now().toString(36)}${Math.floor(Math.random() * 1296).toString(36).padStart(2, '0')}`;",
              "pm.environment.set('employerUsername', `emp${suffix}`.substring(0, 20));",
              "pm.environment.set('employerEmail', `emp${suffix}@example.com`);",
              "pm.environment.set('employerPassword', 'password123');"
            ]
