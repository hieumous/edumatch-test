{
  "info": {
    "_postman_id": "b42b0d5c-8a59-4f0a-a2ad-6c1d7b4c1a11",
    "name": "EduMatch (local) - Smoke",
    "description": "Smoke API suite for EduMatch using direct service ports in CI/local. Order: auth health -> login -> me -> scholarships search.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Scholarship Debug Health",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('JSON body', () => pm.response.to.be.json);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8082/debug/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["debug", "health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (admin/admin123)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has accessToken', () => pm.expect(json.accessToken).to.exist);",
                  "if (json.accessToken) pm.environment.set('accessToken', json.accessToken);",
                  "if (json.refreshToken) pm.environment.set('refreshToken', json.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"admin\",\"password\":\"admin123\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "http://localhost:8081/api/auth/signin",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api", "auth", "signin"]
            }
          },
          "response": []
        },
        {
          "name": "Get Me (auth-service)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "if (json.id != null) pm.environment.set('userId', json.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8081/api/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["api", "auth", "me"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Scholarships",
      "item": [
        {
          "name": "Search Scholarships (public)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Has content/page', () => pm.expect(json).to.have.property('content'));",
                  "if (json.content && json.content.length > 0) {",
                  "  const first = json.content[0];",
                  "  const opp = first.opportunity ? first.opportunity : first;",
                  "  if (opp && opp.id != null) pm.environment.set('opportunityId', opp.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8082/api/scholarships?q=&page=0&size=10",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8082",
              "path": ["api", "scholarships"],
              "query": [
                { "key": "q", "value": "" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}

